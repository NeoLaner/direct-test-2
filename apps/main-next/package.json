{
	"name": "main-next",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"check": "biome check && tsc --noEmit",
		"check:ci": "biome ci && tsc --noEmit",
		"dev": "next dev -p 3021 --turbo",
		"dev:inspect": "cross-env NODE_OPTIONS='--inspect' next dev -p 3021 --turbo",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome check",
		"lint:fix": "biome check --write --unsafe",
		"preview": "next build && next start",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"auth:generate": "pnpx @better-auth/cli generate --config ./src/lib/auth/index.ts --output ../../packages/db/src/tables/auth.ts",
		"auth:migrate": "pnpx @better-auth/cli migrate --output ../../packages/db/src/tables/auth.ts"
	},
	"dependencies": {
		"@orpc/client": "^1.12.1",
		"@orpc/openapi": "^1.12.1",
		"@orpc/react": "^1.12.1",
		"@orpc/tanstack-query": "^1.12.1",
		"@orpc/zod": "^1.12.1",
		"@t3-oss/env-nextjs": "^0.13.8",
		"@tanstack/react-query": "^5.90.11",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@uidotdev/usehooks": "^2.4.1",
		"@workspace/db": "workspace:*",
		"@workspace/rpc-server": "workspace:*",
		"@workspace/ui": "workspace:*",
		"class-variance-authority": "^0.7.1",
		"drizzle-orm": "^0.44.7",
		"geist": "^1.5.1",
		"lucide-react": "^0.475.0",
		"next": "^16.1.0",
		"postgres": "^3.4.7",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"server-only": "^0.0.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@faker-js/faker": "^9.9.0",
		"@tailwindcss/postcss": "^4.1.17",
		"@types/node": "^22.19.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@workspace/typescript-config": "workspace:*",
		"cross-env": "^7.0.3",
		"postcss": "^8.5.6",
		"postcss-load-config": "^6.0.1",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3"
	},
