		"@orpc/server": "catalog:",
		"server-only": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@turbo/gen": "catalog:",
		"@types/node": "catalog:",
		"@workspace/typescript-config": "workspace:*",
		"@workspace/db": "workspace:*",
		"drizzle-orm": "catalog:",
		"cross-env": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./routers": "./src/routers/index.ts",
		"./schemas": "./src/lib/schemas/index.ts"
	}
