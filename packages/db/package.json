{
	"name": "@workspace/db",
	"version": "0.0.1",
	"type": "module",
	"author": "neolaner",
	"scripts": {
		"dev": "drizzle-kit studio",
		"check": "biome check && tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome check",
		"lint:fix": "biome check --write --unsafe",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:pull": "pnpm drizzle-kit pull",
		"db:seed": "tsx --env-file=.env src/lib/seed.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "catalog:",
		"drizzle-zod": "catalog:",
		"postgres": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@turbo/gen": "catalog:",
		"@types/node": "catalog:",
		"@workspace/typescript-config": "workspace:*",
		"cross-env": "catalog:",
		"drizzle-kit": "^0.31.7",
		"tsx": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./tables": "./src/tables/index.ts",
		"./tables/*": "./src/tables/*.ts",
		"./lib": "./src/lib/index.ts",
		"./lib/*": "./src/lib/*.ts",
		"./lib/types": "./src/lib/types/index.ts"
	}
}
